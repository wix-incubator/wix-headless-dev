---
import Layout from "../../layouts/Layout.astro";
import Topbar from "../../components/Topbar.astro";
import Footer from "../../components/Footer.astro";
import CopyPrompt from "../../components/CopyPrompt.tsx";
import PromptTitle from "../../components/PromptTitle.tsx";
import "../../styles/welcome.css";
import "../../styles/site-ready.css";

// Hidden, per-user landing page at /deployed/:clientId. Reached only via the URL
// we hand back to vibe-design platforms (Claude Design, etc.) after we provision
// a hosted Managed Headless site from a design they "sent" us. Not linked from
// anywhere in the site's navigation, and noindex'd below.
//
// The path param is the app's client id. We resolve it server-side via the
// app-service API, then read the HEADLESS_OAUTH component for:
//   siteId               → dashboard / download / domains links
//   redirectUrlWixPages  → the live site URL (visit + preview)
// Anything we can't resolve renders a friendly 404 state (status 404).
const { clientId } = Astro.params;

// Client ids are alphanumeric + dashes (the API wants a GUID). Reject anything
// else before putting it in the fetch URL.
const safeClientId = clientId && /^[A-Za-z0-9-]+$/.test(clientId) ? clientId : null;

// Only ever surface http(s) — never let a javascript:/data: URL from the API
// reach an href/iframe.
function safeHttpUrl(raw: unknown): string | null {
  if (typeof raw !== "string" || !raw) return null;
  try {
    const u = new URL(raw);
    return u.protocol === "http:" || u.protocol === "https:" ? u.toString() : null;
  } catch {
    return null;
  }
}

let headlessOauth: { siteId?: unknown; redirectUrlWixPages?: unknown } | null = null;
if (safeClientId) {
  try {
    const res = await fetch(
      `https://dev.wix.com/_api/app-service/v1/apps/${safeClientId}`,
      { headers: { accept: "application/json" } },
    );
    if (res.ok) {
      const app = await res.json();
      const components = app?.components ?? app?.app?.components;
      headlessOauth =
        components?.find((c: any) => c?.compType === "HEADLESS_OAUTH")
          ?.compData?.headlessOauth ?? null;
    }
  } catch {
    headlessOauth = null;
  }
}

const rawSiteId = headlessOauth?.siteId;
const siteId =
  typeof rawSiteId === "string" && /^[A-Za-z0-9-]+$/.test(rawSiteId) ? rawSiteId : null;
const siteUrl = safeHttpUrl(headlessOauth?.redirectUrlWixPages);

// Couldn't resolve the site behind this client id → render the 404 state.
const notFound = !siteId || !siteUrl;
if (notFound) {
  Astro.response.status = 404;
}

// `.zip` suffix so the URL the agent reads in the prompt visibly ends in a
// recognizable archive extension (the endpoint also serves it as a named
// attachment via Content-Disposition).
const downloadUrl = siteId ? `https://www.wix.com/_api/wixstro-deployments/v1/instant-sites/${siteId}/download.zip` : null;
const dashboardUrl = siteId ? `https://manage.wix.com/dashboard/${siteId}` : null;
const domainsUrl = siteId ? `https://manage.wix.com/dashboard/${siteId}/domain-settings` : null;

// Strip the scheme for a cleaner address-bar label (example.com vs https://…).
const siteLabel = siteUrl ? siteUrl.replace(/^https?:\/\//, "").replace(/\/$/, "") : null;

// Only nudge to connect a custom domain while the site is still on a Wix
// domain (e.g. *.wixsite.com). Once a custom domain is connected the URL no
// longer contains "wix", so the nudge drops away.
const showConnectDomain = !!siteUrl && /wix/i.test(siteUrl);

const headline = notFound ? "We couldn't find that site" : "Your site is live";

// The prompt the user pastes back into their coding agent. The box shows a
// short, human-readable version (with the host accent-styled); the clipboard
// gets the fuller machine-ready version carrying the real download URL.
// Display lines as styled segments — same tone trick as the home prompt:
// framing words grayed (tone "muted"), the host accent-styled (tone "host").
const promptDisplayLines = [
  [
    { text: "Pick up ", tone: "muted" },
    { text: "where I left off with Wix Headless." },
  ],
  [
    { text: "Download ", tone: "muted" },
    { text: "my design and switch on only the features it needs" },
  ],
  [
    { text: "Using ", tone: "muted" },
    { text: "wix-headless.dev", tone: "host" },
  ],
];
const promptCopyText = notFound
  ? ""
  : `Help me keep building my Wix Headless site — download my project from ${downloadUrl} and follow the guide at wix-headless.dev/skill.md.`;

const description = notFound
  ? "We couldn't find that site. The link may have expired or the site isn't ready yet."
  : "Your hosted Wix Headless site is live. Preview it, then copy the prompt to keep building in your coding agent.";
---

<Layout title={`${headline} | Wix Headless`} description={description} xray={false}>
  <meta slot="seo-tags" name="robots" content="noindex, nofollow" />

  <div class="page" data-deployed-state={notFound ? "not-found" : "live"}>
    <Topbar xray={false} />

    {notFound ? (
      <main class="ready">
        <section class="ready__error">
          <span class="kicker">Error 404</span>
          <h1 class="ready__title">{headline}</h1>
          <p class="ready__sub">
            This link may have expired, or the site isn't ready just yet.
            Double-check the link from your coding platform — or start a fresh
            build from the homepage.
          </p>
          <div class="ready__cta-actions ready__cta--error">
            <a class="ready__btn ready__btn--primary" href="/">Back to homepage</a>
            <a class="ready__btn" href="https://dev.wix.com/docs/go-headless/wix-managed-headless/start-from-your-own-frontend/development-of-a-project-started-from-your-own-frontend" target="_blank" rel="noreferrer" data-track="docs">
              Read the docs
            </a>
          </div>
        </section>
      </main>
    ) : (
      <main class="ready">
        <header class="ready__hero">
          <h1 class="ready__title">{headline}</h1>
          <p class="ready__sub">
            Your design is now a real hosted website, fully managed on Wix infrastucture trusted by millions. Add payments, bookings, a store and more with one prompt.
          </p>
        </header>

        <section class="ready__cards" aria-label="Next steps">
          <article class="ready__card ready__card--site">
            <div class="browser__bar">
              <span class="browser__dots" aria-hidden="true">
                <span></span><span></span><span></span>
              </span>
              <span class="browser__addr">
                <span class="browser__url">{siteLabel}</span>
                {showConnectDomain && (
                  <a class="browser__domain" href={domainsUrl} target="_blank" rel="noreferrer" data-track="connect-domain">
                    Connect domain
                  </a>
                )}
              </span>
            </div>
            <div class="ready__card-hot">
              <a
                class="ready__card-link"
                href={siteUrl}
                target="_blank"
                rel="noreferrer"
                aria-label="Open your live site in a new tab"
                data-track="visit-site"
              ></a>
              <div class="browser browser--card">
                <iframe
                  class="browser__frame"
                  src={siteUrl}
                  title="Your live Wix Headless site"
                  loading="lazy"
                  sandbox="allow-scripts allow-same-origin allow-popups allow-forms"
                  referrerpolicy="no-referrer"
                  tabindex="-1"
                ></iframe>
              </div>
              <div class="ready__card-foot">
                <div class="ready__card-meta">
                  <span class="ready__card-title">Visit your site</span>
                  <span class="ready__card-desc">Your site is live and hosted on Wix. Open it now to see your design in action.</span>
                </div>
                <svg class="ready__card-arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 12L12 4" />
                  <path d="M6 4h6v6" />
                </svg>
              </div>
            </div>
          </article>

          {/* Dashboard — same chrome, with a lightweight skeleton standing in for
              the management dashboard preview. */}
          <article class="ready__card ready__card--dash">
            <a
              class="ready__card-link"
              href={dashboardUrl}
              target="_blank"
              rel="noreferrer"
              aria-label="Open your site dashboard in a new tab"
              data-track="open-dashboard"
            ></a>
            <div class="browser browser--card" aria-hidden="true">
              <div class="browser__bar">
                <span class="browser__dots">
                  <span></span><span></span><span></span>
                </span>
                <span class="browser__addr">
                  <span class="browser__url">manage.wix.com/dashboard</span>
                </span>
              </div>
              <div class="dashmock">
                <aside class="dashmock__side">
                  <span class="dashmock__logo"></span>
                  <span class="dashmock__nav"></span>
                  <span class="dashmock__nav dashmock__nav--active"></span>
                  <span class="dashmock__nav"></span>
                  <span class="dashmock__nav"></span>
                </aside>
                <div class="dashmock__main">
                  <div class="dashmock__row--head">
                    <span class="dashmock__title"></span>
                    <span class="dashmock__btn"></span>
                  </div>
                  <div class="dashmock__cards">
                    <span class="dashmock__stat"></span>
                    <span class="dashmock__stat"></span>
                    <span class="dashmock__stat"></span>
                  </div>
                  <div class="dashmock__chart"></div>
                </div>
              </div>
            </div>
            <div class="ready__card-foot">
              <div class="ready__card-meta">
                <span class="ready__card-title">Manage and scale</span>
                <span class="ready__card-desc">Run your business from one Wix dashboard as you grow.</span>
              </div>
              <svg class="ready__card-arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 12L12 4" />
                <path d="M6 4h6v6" />
              </svg>
            </div>
          </article>
        </section>

        <section class="bento__steps block ready__steps" aria-label="How it works">
          <ol class="steps">
            <li class="step">
              <span class="step__num">01</span>
              <span class="step__verb">Copy</span>
              <span class="step__detail">the prompt</span>
            </li>
            <li class="step">
              <span class="step__num">02</span>
              <span class="step__verb">Paste</span>
              <span class="step__detail">into your agent</span>
            </li>
            <li class="step">
              <span class="step__num">03</span>
              <span class="step__verb">Ship</span>
              <span class="step__detail">on a real Wix <a href="/skill.md">backend</a></span>
            </li>
          </ol>
          <a class="ready__guide" href="https://dev.wix.com/docs/go-headless/wix-managed-headless/start-from-your-own-frontend/development-of-a-project-started-from-your-own-frontend" target="_blank" rel="noreferrer" data-track="guide">
            Read the full guide
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M6 3H3a1 1 0 0 0-1 1v9a1 1 0 0 0 1 1h9a1 1 0 0 0 1-1v-3" />
              <path d="M9 2h5v5" />
              <path d="M14 2L7.5 8.5" />
            </svg>
          </a>
        </section>

        <div id="continue" class="bento__prompt-zone">
          <section class="bento__prompt block" aria-label="Continue with this prompt">
            <PromptTitle client:load lead="Use this with" />
            <CopyPrompt
              lines={promptDisplayLines}
              copyText={promptCopyText}
              client:load
            />
          </section>
        </div>
      </main>
    )}

    <Footer />
  </div>

  <script>
    // Wix-native analytics (same module the Copy button uses). Every CTA
    // tagged with data-track reports a buttonClicked (no payload — it just
    // marks the element as tracked). The 404 state additionally reports a
    // CustomEvent landing. Both are fire-and-forget, so they run fine even on
    // the target="_blank" links right before navigation.
    import { analytics } from "@wix/site";

    const state = document.querySelector(".page")?.getAttribute("data-deployed-state") ?? "unknown";
    // Only the 404 landing is worth a signal; live landings aren't tracked.
    if (state === "not-found") {
      analytics.trackEvent("CustomEvent", {
        eventCategory: "deployed",
        eventAction: "landed",
        eventLabel: state,
      });
    }

    document.addEventListener("click", (e) => {
      const el = (e.target as Element)?.closest?.("[data-track]");
      if (!el) return;
      analytics.buttonClicked();
    });
  </script>
</Layout>
