---
import TryPrompt from "./TryPrompt.tsx";
import PromptTitle from "./PromptTitle.tsx";
import WixLogo from "../assets/wix.svg";
import GithubIcon from "../assets/github.svg";
import "../styles/welcome.css";
---

<div class="page">
  <header class="topbar">
    <a class="wordmark" href="/" aria-label="wix-headless.dev — a Wix project">
      <WixLogo class="wordmark__logo" aria-hidden="true" />
      <span class="wordmark__divider" aria-hidden="true">/</span>
      <span class="wordmark__name">headless</span><span class="wordmark__tld">.dev</span>
    </a>
    <nav class="topnav">
      <a href="/skill">Skill</a>
      <a href="https://dev.wix.com/docs/go-headless" target="_blank" rel="noreferrer">Docs</a>
    </nav>
  </header>

  <main class="bento">
    <section class="bento__hero block">
      <h1 class="hero__title">
        Build anything.<br />
        <span class="hero__title-accent">Wix runs the business behind it.</span>
      </h1>
      <p class="hero__sub">
        Wix Headless lets you build a custom frontend on the stack of your choice, backed by production-ready Wix business APIs and a full management dashboard out of the box.
      </p>
    </section>

    <div class="bento__prompt-zone">
      <section class="bento__prompt block" aria-label="Try the prompt">
        <PromptTitle client:load />
        <TryPrompt client:load />
      </section>
    </div>

    <section class="bento__steps block" aria-label="How it works">
      <ol class="steps">
        <li class="step">
          <span class="step__num">01</span>
          <span class="step__verb">Copy</span>
          <span class="step__detail">the prompt</span>
        </li>
        <li class="step">
          <span class="step__num">02</span>
          <span class="step__verb">Paste</span>
          <span class="step__detail">into your agent</span>
        </li>
        <li class="step">
          <span class="step__num">03</span>
          <span class="step__verb">Ship</span>
          <span class="step__detail">on a real Wix <a href="/skill">backend</a></span>
        </li>
      </ol>
    </section>

    <section class="bento__features block" aria-labelledby="features-title">
      <header class="features__header">
        <span class="kicker">out of the box</span>
        <h2 id="features-title" class="features__title">Skip the backend.</h2>
        <p class="features__lede">
          Production-ready APIs for everything that isn&rsquo;t UI &mdash; managed by Wix, called from your frontend.
        </p>
      </header>
      <ul class="features">
        <li class="feature">
          <span class="feature__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5.5 8h13l-1 12.5h-11L5.5 8z" />
              <path d="M9 8V5.5a3 3 0 0 1 6 0V8" />
            </svg>
          </span>
          <h3 class="feature__name">Commerce</h3>
          <p class="feature__desc">Storefronts, cart, checkout, orders.</p>
        </li>
        <li class="feature">
          <span class="feature__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3.5" y="5" width="17" height="15.5" rx="2" />
              <path d="M3.5 10.5h17" />
              <path d="M8 3v4M16 3v4" />
              <circle cx="12" cy="15" r="1.4" fill="currentColor" stroke="none" />
            </svg>
          </span>
          <h3 class="feature__name">Bookings</h3>
          <p class="feature__desc">Services, sessions, calendar, payments.</p>
        </li>
        <li class="feature">
          <span class="feature__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3.5" y="4" width="17" height="4.5" rx="1" />
              <rect x="3.5" y="9.75" width="17" height="4.5" rx="1" />
              <rect x="3.5" y="15.5" width="17" height="4.5" rx="1" />
              <circle cx="7" cy="6.25" r="0.6" fill="currentColor" stroke="none" />
              <circle cx="7" cy="12" r="0.6" fill="currentColor" stroke="none" />
              <circle cx="7" cy="17.75" r="0.6" fill="currentColor" stroke="none" />
            </svg>
          </span>
          <h3 class="feature__name">CMS</h3>
          <p class="feature__desc">Content collections, queries, schemas.</p>
        </li>
        <li class="feature">
          <span class="feature__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3l8 2.5v6c0 5-3.5 8-8 9.5-4.5-1.5-8-4.5-8-9.5v-6L12 3z" />
              <path d="M8.5 12l2.5 2.5L15.5 10" />
            </svg>
          </span>
          <h3 class="feature__name">Auth</h3>
          <p class="feature__desc">Members, identity, sessions.</p>
        </li>
      </ul>
    </section>
  </main>

  <footer class="footer">
    <div class="footer__row">
      <a class="footer__brand footer__powered" href="https://dev.wix.com/docs/go-headless" target="_blank" rel="noreferrer">
        <span class="footer__powered-prefix">Powered by Wix Headless</span>
      </a>
      <nav class="footer__nav" aria-label="Footer">
        <a href="https://github.com/wix-incubator/wix-headless-dev" target="_blank" rel="noreferrer" class="footer__github">
          <GithubIcon aria-hidden="true" />
          GitHub
        </a>
        <a href="https://www.wix.com/about/terms-of-use" target="_blank" rel="noreferrer">Terms of Use</a>
        <a href="https://www.wix.com/about/privacy" target="_blank" rel="noreferrer">Privacy Policy</a>
      </nav>
    </div>
    <div class="footer__legal">
      <span>&copy; 2026 Wix.com</span>
    </div>
  </footer>
</div>
