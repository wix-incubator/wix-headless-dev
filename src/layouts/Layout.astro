---
import "../styles/xray.css";
import XRayLayer from "../components/xray/Layer.tsx";

const SITE_URL = "https://www.wix-headless.dev";
const {
	title = "Wix Headless | Build anything. Wix runs the business behind it.",
	description = "Headless commerce, bookings, CMS, identity — agent-wired, prompt-deep. Drop one prompt into any coding agent and ship a real Wix site.",
	ogTitle = "Build anything. Wix runs the business behind it.",
	ogDescription = "Headless commerce, bookings, CMS, identity — agent-wired, prompt-deep.",
	image = "/og-image.png",
	imageAlt = "Wix Headless — Build anything. Wix runs the business behind it.",
	canonical = SITE_URL + "/",
} = Astro.props;
const absoluteImage = image.startsWith("http") ? image : SITE_URL + image;
const bSession = Astro.cookies.get("bSession")?.value ?? "";
---
<!doctype html>
<html lang="en" data-bsession={bSession}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" sizes="192x192" href="/icon.png" />
		<link rel="apple-touch-icon" href="/icon.png" />
		<meta name="generator" content={Astro.generator} />
		<meta name="author" content="Wix.com, Inc." />
		<link rel="canonical" href={canonical} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:site_name" content="wix-headless.dev" />
		<meta property="og:title" content={ogTitle} />
		<meta property="og:description" content={ogDescription} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={absoluteImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={imageAlt} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@Wix" />
		<meta name="twitter:title" content={ogTitle} />
		<meta name="twitter:description" content={ogDescription} />
		<meta name="twitter:image" content={absoluteImage} />
		<meta name="twitter:image:alt" content={imageAlt} />
		<meta name="theme-color" content="#0a0a0a" />
		<link rel="preconnect" href="https://rsms.me/" />
		<link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
		<script>
			const POSTHOG_KEY = import.meta.env.PUBLIC_POSTHOG_KEY;
			const POSTHOG_HOST =
				import.meta.env.PUBLIC_POSTHOG_HOST || "https://us.i.posthog.com";

			const params = new URLSearchParams(window.location.search);
			const active =
				params.get("funnel") === "1" ||
				window.sessionStorage.getItem("funnel") === "1";

			if (active && POSTHOG_KEY) {
				window.sessionStorage.setItem("funnel", "1");
				// Dynamic import keeps posthog-js out of the bundle for non-funnel pages.
				const { default: posthog } = await import("posthog-js");
				const bSession = document.documentElement.dataset.bsession || "";
				posthog.init(POSTHOG_KEY, {
					api_host: POSTHOG_HOST,
					bootstrap: bSession ? { distinctID: bSession } : undefined,
					capture_pageview: false,
					person_profiles: "identified_only",
				});
				(window as any).posthog = posthog;
				posthog.capture("funnel_page_viewed", {
					path: window.location.pathname,
					referrer: document.referrer || undefined,
				});
			}
		</script>
	</head>
	<body>
		<slot />
		<XRayLayer client:load />
	</body>
</html>
