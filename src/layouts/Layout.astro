---
import "../styles/xray.css";
import XRayLayer from "../components/xray/Layer.tsx";
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" sizes="192x192" href="/icon.png" />
		<link rel="apple-touch-icon" href="/icon.png" />
		<meta name="generator" content={Astro.generator} />
		<meta name="author" content="Wix.com, Inc." />
		<link rel="canonical" href="https://wix-headless.dev/" />
		<title>
			Wix Headless | Build anything. Wix runs the business behind it.
		</title>
		<meta
			name="description"
			content="Headless commerce, bookings, CMS, identity — agent-wired, prompt-deep. Drop one prompt into any coding agent and ship a real Wix site."
		/>
		<meta property="og:site_name" content="wix-headless.dev" />
		<meta
			property="og:title"
			content="Build anything. Wix runs the business behind it."
		/>
		<meta
			property="og:description"
			content="Headless commerce, bookings, CMS, identity — agent-wired, prompt-deep."
		/>
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://wix-headless.dev/" />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:site" content="@Wix" />
		<meta
			name="twitter:title"
			content="wix-headless.dev — Build anything. Wix runs the business behind it."
		/>
		<meta
			name="twitter:description"
			content="Headless commerce, bookings, CMS, identity — agent-wired, prompt-deep."
		/>
		<meta name="theme-color" content="#0a0a0a" />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@graph": [
				{
					"@type": "Organization",
					"@id": "https://wix-headless.dev/#org",
					name: "Wix Headless",
					url: "https://wix-headless.dev/",
					logo: "https://wix-headless.dev/icon.png",
					sameAs: [
						"https://github.com/wix-incubator/wix-headless-dev",
						"https://twitter.com/Wix",
					],
				},
				{
					"@type": "WebSite",
					"@id": "https://wix-headless.dev/#site",
					url: "https://wix-headless.dev/",
					name: "wix-headless.dev",
					description: "Headless commerce, bookings, CMS, identity — agent-wired, prompt-deep. Drop one prompt into any coding agent and ship a real Wix site.",
					publisher: { "@id": "https://wix-headless.dev/#org" },
				},
			],
		})} />
		<link rel="preconnect" href="https://rsms.me/" />
		<link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
	</head>
	<body>
		<slot />
		<XRayLayer client:load />
	</body>
</html>
