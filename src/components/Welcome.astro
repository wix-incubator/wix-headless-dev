---
import TryPrompt from "./TryPrompt.tsx";
---

<div class="page">
  <header class="topbar">
    <a class="wordmark" href="/" aria-label="wix-headless.dev — a Wix project">
      <svg class="wordmark__logo" viewBox="0 0 166 64" aria-hidden="true">
        <path d="M165.304 0H156.173C153.64 0 151.273 1.25433 149.85 3.35199L137.639 21.3662C137.313 21.844 136.608 21.844 136.283 21.3662L124.071 3.35199C122.651 1.25433 120.281 0 117.748 0H108.617L130.371 32.0894L108.737 64H117.868C120.401 64 122.769 62.7457 124.192 60.648L136.283 42.8126C136.608 42.3349 137.313 42.3349 137.639 42.8126L149.73 60.648C151.15 62.7457 153.52 64 156.053 64H165.184L143.551 32.0894L165.304 0Z"/>
        <path d="M89.8281 6.54652V64H94.1922C97.8088 64 100.74 61.0697 100.74 57.4535V0H96.3755C92.7588 0 89.8281 2.93032 89.8281 6.54652Z"/>
        <path d="M81.8276 0H77.944C73.6681 0 69.9633 2.95701 69.0158 7.12564L60.3278 45.3185L52.7234 9.66632C51.3168 3.0771 44.5559 -1.36641 37.6375 0.544431C33.2307 1.76139 29.9637 5.48434 29.0108 9.95455L21.4839 45.2705L12.8118 7.12831C11.8616 2.95968 8.15687 0 3.88092 0H0L14.5548 63.9973H20.0692C25.0738 63.9973 29.3978 60.4986 30.4415 55.604L39.7461 11.9401C39.8608 11.3984 40.3466 11.006 40.8991 11.006C41.4516 11.006 41.9374 11.3984 42.0522 11.9401L51.3648 55.6067C52.4084 60.5012 56.7324 63.9973 61.7371 63.9973H67.2702L81.8276 0Z"/>
      </svg>
      <span class="wordmark__divider" aria-hidden="true">/</span>
      <span class="wordmark__name">headless</span><span class="wordmark__tld">.dev</span>
    </a>
    <nav class="topnav">
      <a href="/skill">skill</a>
      <a href="https://dev.wix.com/docs/go-headless" target="_blank" rel="noreferrer">Docs</a>
      <a href="https://dev.wix.com" target="_blank" rel="noreferrer">dev.wix.com</a>
    </nav>
  </header>

  <main class="hero">
    <h1 class="hero__title">
      Build anything.<br />
      <span class="hero__title-accent">Wix runs the business behind it.</span>
    </h1>
    <p class="hero__sub">
      Headless commerce, bookings, CMS, identity &mdash; agent-wired, prompt-deep.
    </p>

    <TryPrompt client:load />

    <div class="agents">
      <span class="agents__label">Works in</span>
      <span class="agents__list">
        <span>Claude Code</span>
        <span class="agents__dot">·</span>
        <span>Cursor</span>
        <span class="agents__dot">·</span>
        <span>Codex</span>
        <span class="agents__dot">·</span>
        <span>any agent that fetches URLs</span>
      </span>
    </div>
  </main>

  <section class="how">
    <ol class="how__steps">
      <li>
        <span class="how__num">1</span>
        <span class="how__text"><b>Copy</b> the prompt above.</span>
      </li>
      <li>
        <span class="how__num">2</span>
        <span class="how__text"><b>Paste</b> into your coding agent.</span>
      </li>
      <li>
        <span class="how__num">3</span>
        <span class="how__text">Your agent fetches <a href="/skill"><code>/skill</code></a> and ships a real Wix site.</span>
      </li>
    </ol>
  </section>

  <footer class="footer">
    <div class="footer__row">
      <a class="footer__brand footer__powered" href="https://dev.wix.com/docs/go-headless" target="_blank" rel="noreferrer">
        <span class="footer__powered-prefix">Powered by</span>
        <svg class="footer__logo" viewBox="0 0 166 64" aria-hidden="true">
          <path d="M165.304 0H156.173C153.64 0 151.273 1.25433 149.85 3.35199L137.639 21.3662C137.313 21.844 136.608 21.844 136.283 21.3662L124.071 3.35199C122.651 1.25433 120.281 0 117.748 0H108.617L130.371 32.0894L108.737 64H117.868C120.401 64 122.769 62.7457 124.192 60.648L136.283 42.8126C136.608 42.3349 137.313 42.3349 137.639 42.8126L149.73 60.648C151.15 62.7457 153.52 64 156.053 64H165.184L143.551 32.0894L165.304 0Z"/>
          <path d="M89.8281 6.54652V64H94.1922C97.8088 64 100.74 61.0697 100.74 57.4535V0H96.3755C92.7588 0 89.8281 2.93032 89.8281 6.54652Z"/>
          <path d="M81.8276 0H77.944C73.6681 0 69.9633 2.95701 69.0158 7.12564L60.3278 45.3185L52.7234 9.66632C51.3168 3.0771 44.5559 -1.36641 37.6375 0.544431C33.2307 1.76139 29.9637 5.48434 29.0108 9.95455L21.4839 45.2705L12.8118 7.12831C11.8616 2.95968 8.15687 0 3.88092 0H0L14.5548 63.9973H20.0692C25.0738 63.9973 29.3978 60.4986 30.4415 55.604L39.7461 11.9401C39.8608 11.3984 40.3466 11.006 40.8991 11.006C41.4516 11.006 41.9374 11.3984 42.0522 11.9401L51.3648 55.6067C52.4084 60.5012 56.7324 63.9973 61.7371 63.9973H67.2702L81.8276 0Z"/>
        </svg>
        <span class="footer__powered-name">Headless</span>
      </a>
      <nav class="footer__nav" aria-label="Footer">
        <a href="/skill">Download skill bundle</a>
        <a href="https://github.com/wix-incubator/wix-headless-dev" target="_blank" rel="noreferrer" class="footer__github">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.08c-3.2.69-3.87-1.34-3.87-1.34-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.58.23 2.75.11 3.04.74.81 1.19 1.84 1.19 3.1 0 4.42-2.7 5.4-5.26 5.68.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.79.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
          </svg>
          GitHub
        </a>
        <a href="https://dev.wix.com/skills/wix-headless" target="_blank" rel="noreferrer">Source on dev.wix.com</a>
        <a href="https://dev.wix.com/docs/go-headless" target="_blank" rel="noreferrer">Headless docs</a>
        <a href="https://www.wix.com/about/terms-of-use" target="_blank" rel="noreferrer">Terms of Use</a>
        <a href="https://www.wix.com/about/privacy" target="_blank" rel="noreferrer">Privacy Policy</a>
        <a href="https://www.wix.com" target="_blank" rel="noreferrer">wix.com</a>
      </nav>
    </div>
    <div class="footer__legal">
      <span>&copy; 2006&ndash;2026 Wix.com, Inc. All rights reserved.</span>
      <span class="footer__sep">·</span>
      <span>Wix&reg; and the Wix logo are registered trademarks of Wix.com Ltd.</span>
    </div>
  </footer>
</div>

<style is:global>
  :root {
    --bg: #0a0a0a;
    --bg-card: #111114;
    --border: #1f1f23;
    --border-strong: #2a2a2f;
    --fg: #f5f5f7;
    --fg-muted: #8a8a93;
    --fg-faint: #5a5a62;
    --accent: #faff00;
    --accent-fade: rgba(250, 255, 0, 0.12);
    --mono: ui-monospace, "SF Mono", Menlo, Consolas, "Liberation Mono", monospace;
    --sans: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: var(--bg); color: var(--fg); font-family: var(--sans); -webkit-font-smoothing: antialiased; }
</style>

<style>
  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    padding: 24px clamp(20px, 6vw, 56px);
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
  }

  .topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 48px;
  }
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--mono);
    font-size: 16px;
    color: var(--fg);
    text-decoration: none;
    letter-spacing: -0.01em;
  }
  .wordmark__logo {
    height: 18px;
    width: auto;
    fill: var(--fg);
    display: inline-block;
  }
  .wordmark__divider {
    color: var(--fg-faint);
    font-weight: 300;
  }
  .wordmark__tld { color: var(--fg-muted); }
  .topnav { display: flex; gap: 24px; }
  .topnav a {
    color: var(--fg-muted);
    text-decoration: none;
    font-size: 14px;
    font-family: var(--mono);
  }
  .topnav a:hover { color: var(--fg); }

  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: clamp(40px, 8vh, 96px) 0 56px;
  }
  .hero__title {
    font-size: clamp(40px, 6vw, 64px);
    line-height: 1.05;
    font-weight: 600;
    letter-spacing: -0.03em;
    margin: 0 0 20px;
    max-width: 900px;
  }
  .hero__title-accent {
    background: linear-gradient(110deg, #f5f5f7 0%, #8a8a93 60%, #f5f5f7 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero__sub {
    font-size: clamp(15px, 1.4vw, 17px);
    color: var(--fg-muted);
    margin: 0 0 40px;
    max-width: 620px;
    line-height: 1.5;
  }

  .agents {
    margin-top: 28px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 13px;
    color: var(--fg-faint);
  }
  .agents__label { color: var(--fg-muted); }
  .agents__list { display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; }
  .agents__dot { color: var(--fg-faint); }

  .how {
    padding: 56px 0 32px;
    border-top: 1px solid var(--border);
  }
  .how__steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  @media (max-width: 720px) {
    .how__steps { grid-template-columns: 1fr; }
  }
  .how__steps li {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    font-size: 14px;
    color: var(--fg-muted);
    line-height: 1.5;
  }
  .how__num {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--fg-faint);
    border: 1px solid var(--border-strong);
    border-radius: 6px;
    width: 24px;
    height: 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 24px;
  }
  .how__text b { color: var(--fg); font-weight: 500; }
  .how__text code {
    font-family: var(--mono);
    font-size: 12px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 1px 6px;
    border-radius: 4px;
    color: var(--fg);
  }
  .how__text a { color: var(--fg-muted); text-decoration: underline; text-decoration-color: var(--border-strong); }
  .how__text a:hover { color: var(--fg); }

  .footer {
    margin-top: auto;
    padding-top: 48px;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 20px;
    color: var(--fg-faint);
    font-size: 13px;
    font-family: var(--mono);
  }
  .footer__row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 20px;
  }
  .footer__brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .footer__powered {
    color: var(--fg-muted);
  }
  .footer__powered:hover { color: var(--fg); }
  .footer__powered:hover .footer__logo { fill: var(--fg); }
  .footer__powered-prefix,
  .footer__powered-name {
    font-size: 13px;
  }
  .footer__powered-name { color: inherit; }
  .footer__logo {
    height: 14px;
    width: auto;
    fill: var(--fg-muted);
    transition: fill 0.15s ease;
  }
  .footer__nav {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
    justify-content: flex-end;
    align-items: center;
  }
  .footer__github {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .footer__github svg {
    width: 14px;
    height: 14px;
    fill: currentColor;
    flex: 0 0 auto;
  }
  .footer__legal {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
    color: var(--fg-faint);
    font-size: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--border);
  }
  .footer__sep { color: var(--border-strong); }
  .footer a { color: var(--fg-muted); text-decoration: none; }
  .footer a:hover { color: var(--fg); }

  /* TryPrompt component styles */
  :global(.tryprompt) {
    width: 100%;
    max-width: 720px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }
  :global(.tryprompt__box) {
    width: 100%;
    background: var(--bg-card);
    border: 1px solid var(--border-strong);
    border-radius: 12px;
    padding: 18px 18px 18px 22px;
    display: flex;
    align-items: center;
    gap: 16px;
    cursor: text;
    transition: border-color 0.15s ease, background 0.15s ease;
    text-align: left;
  }
  :global(.tryprompt__box:hover) {
    border-color: #3a3a40;
    background: #131318;
  }
  :global(.tryprompt__box:focus-within) {
    border-color: #4a4a52;
    background: #131318;
  }
  :global(.tryprompt__line) {
    flex: 1;
    font-family: var(--mono);
    font-size: clamp(14px, 1.4vw, 16px);
    line-height: 1.5;
    color: var(--fg);
    min-width: 0;
  }
  :global(.tryprompt__label) {
    color: var(--fg-faint);
    margin-right: 8px;
  }
  :global(.tryprompt__body) {
    color: var(--fg);
  }
  :global(.tryprompt__static) { color: var(--fg-muted); }
  :global(.tryprompt__intent) { color: var(--fg); }
  :global(.tryprompt__intent-input) {
    background: transparent;
    border: none;
    outline: none;
    color: var(--fg);
    font: inherit;
    letter-spacing: inherit;
    padding: 0;
    margin: 0;
    max-width: 100%;
    min-width: 0;
    caret-color: var(--fg);
  }
  :global(.tryprompt__intent-input::placeholder) {
    color: var(--fg-faint);
    opacity: 1;
  }
  :global(.tryprompt__host) {
    color: var(--accent);
    background: var(--accent-fade);
    padding: 1px 6px;
    border-radius: 4px;
  }
  :global(.tryprompt__caret) {
    display: inline-block;
    width: 0;
    margin-left: 1px;
    color: var(--fg);
    animation: blink 1.05s steps(1) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  :global(.tryprompt__copy) {
    flex: 0 0 auto;
    background: transparent;
    color: var(--fg-muted);
    border: 1px solid var(--border-strong);
    border-radius: 8px;
    padding: 8px 14px;
    font-family: var(--mono);
    font-size: 13px;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  :global(.tryprompt__copy:hover) { color: var(--fg); border-color: #3a3a40; }
  :global(.tryprompt__copy.is-copied) {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-fade);
  }
  @media (max-width: 600px) {
    :global(.tryprompt__box) {
      flex-direction: column;
      align-items: stretch;
      gap: 12px;
    }
    :global(.tryprompt__copy) { align-self: flex-end; }
  }
</style>
